# ===========================================
# SECURITY NOTICE: 
# - NEVER commit .env.local with real values to git
# - Use different secrets for development/production
# - Rotate keys regularly (every 90 days minimum)
# - Use strong, unique passwords/secrets
# ===========================================

# Environment
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/[ref]/settings/api
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Database direct connection (for migrations)
DATABASE_URL=postgresql://user:password@host:port/database

# Security Keys (generate with: openssl rand -base64 32)
ENCRYPTION_KEY=your_32_character_encryption_key_here
JWT_SECRET=your_jwt_secret_key_here
CSRF_SECRET=your_csrf_secret_key_here

# Session Configuration
SESSION_SECRET=your_session_secret_here
SESSION_TIMEOUT=3600000

# Mux Configuration (for video uploads)
MUX_TOKEN_ID=your_mux_token_id_here
MUX_TOKEN_SECRET=your_mux_token_secret_here
MUX_WEBHOOK_SECRET=your_mux_webhook_secret_here
MUX_SIGNING_KEY=your_mux_signing_key_here

# Discord OAuth (optional - for gaming community features)
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Game API Integrations
NEXT_PUBLIC_STEAM_API_KEY=your_steam_web_api_key_here
NEXT_PUBLIC_EPIC_CLIENT_ID=your_epic_games_client_id_here
NEXT_PUBLIC_EPIC_CLIENT_SECRET=your_epic_games_client_secret_here
NEXT_PUBLIC_XBOX_CLIENT_ID=your_xbox_client_id_here
NEXT_PUBLIC_XBOX_CLIENT_SECRET=your_xbox_client_secret_here
NEXT_PUBLIC_PSN_CLIENT_ID=your_psn_client_id_here
NEXT_PUBLIC_PSN_CLIENT_SECRET=your_psn_client_secret_here
NEXT_PUBLIC_NINTENDO_CLIENT_ID=your_nintendo_client_id_here
NEXT_PUBLIC_NINTENDO_CLIENT_SECRET=your_nintendo_client_secret_here
NEXT_PUBLIC_GOG_CLIENT_ID=your_gog_client_id_here
NEXT_PUBLIC_GOG_CLIENT_SECRET=your_gog_client_secret_here
NEXT_PUBLIC_RIOT_API_KEY=your_riot_games_api_key_here
NEXT_PUBLIC_BLIZZARD_CLIENT_ID=your_blizzard_client_id_here
NEXT_PUBLIC_BLIZZARD_CLIENT_SECRET=your_blizzard_client_secret_here

# Streaming Configuration
RTMP_SERVER_URL=rtmp://stream.ignisstream.com/live
HLS_SERVER_URL=https://stream.ignisstream.com/hls
STREAMING_SECRET_KEY=your_streaming_secret_key_here

# Third-party integrations
TWITCH_CLIENT_ID=your_twitch_client_id_here
TWITCH_CLIENT_SECRET=your_twitch_client_secret_here
YOUTUBE_API_KEY=your_youtube_api_key_here

# Email Service (for notifications)
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=noreply@ignisstream.com

# File Upload Security
MAX_FILE_SIZE=10485760
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif
ALLOWED_VIDEO_TYPES=video/mp4,video/webm,video/ogg

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# Monitoring & Analytics
SENTRY_DSN=your_sentry_dsn_here
GOOGLE_ANALYTICS_ID=your_ga_id_here

# Production Security Settings
ALLOWED_ORIGINS=http://localhost:3000,https://ignisstream.com
CORS_ENABLED=true
SESSION_COOKIE_SECURE=true
COOKIE_SAME_SITE=strict

# WebSocket Configuration
WEBSOCKET_PORT=3001
WEBSOCKET_SECURE=false
WEBSOCKET_CORS_ORIGINS=http://localhost:3000,https://ignisstream.com

# ML & Analytics Services
ML_API_ENDPOINT=https://api.ignisstream.com/ml
ML_API_KEY=your_ml_api_key_here
ANALYTICS_PROVIDER=vercel
ANALYTICS_ID=your_analytics_id_here

# Content Moderation
CONTENT_MODERATION_API_KEY=your_moderation_api_key_here
AUTO_MODERATION_ENABLED=true
PROFANITY_FILTER_ENABLED=true

# Performance & Caching
REDIS_URL=redis://localhost:6379
CDN_URL=https://cdn.ignisstream.com
CACHE_TTL=3600

# Error Tracking & Logging
LOG_LEVEL=info
ERROR_REPORTING_ENABLED=true
PERFORMANCE_MONITORING=true

# Development Only
DISABLE_SSL_VERIFY=false
ENABLE_DEBUG_LOGS=false
MOCK_API_RESPONSES=false
